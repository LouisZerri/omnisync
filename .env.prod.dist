# Secrets de production — copier en .env.prod et renseigner les vraies valeurs.
# .env.prod ne doit JAMAIS être commité ni copié dans l'image (il est ignoré par git et docker).
# Utilisé par : docker compose -f compose.prod.yaml --env-file .env.prod ...

# Secret applicatif Symfony — générer avec : php -r "echo bin2hex(random_bytes(16));"
APP_SECRET=

# Mot de passe de l'utilisateur applicatif MySQL (omnisync)
MYSQL_PASSWORD=
# Mot de passe root MySQL
MYSQL_ROOT_PASSWORD=

# Mot de passe RabbitMQ (utilisateur omnisync)
RABBITMQ_PASSWORD=

# Clé secrète Mercure (signe/valide les JWT publisher & subscriber) — une seule valeur
MERCURE_JWT_SECRET=

# (Optionnel) DSN du mailer ; par défaut aucun envoi d'e-mail (null://null)
# MAILER_DSN=
