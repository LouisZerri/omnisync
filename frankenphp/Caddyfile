{
	{$CADDY_GLOBAL_OPTIONS}

	frankenphp {
		{$FRANKENPHP_CONFIG}
	}
}

{$CADDY_EXTRA_CONFIG}

# SERVER_NAME=:8080 en prod → FrankenPHP sert en HTTP sur 8080, derrière Apache
# qui termine le TLS. En local on peut surcharger SERVER_NAME pour activer l'HTTPS auto.
{$SERVER_NAME:localhost} {
	log {
		output stderr
	}

	root * /app/public
	encode zstd br gzip

	# Hub Mercure intégré : servi sur /.well-known/mercure, même origine que l'app
	# (donc plus aucun souci de mixed-content / certificat comme en dev).
	mercure {
		transport_url {$MERCURE_TRANSPORT_URL:bolt:///app/var/mercure.db}
		publisher_jwt {env.MERCURE_PUBLISHER_JWT_KEY}
		subscriber_jwt {env.MERCURE_SUBSCRIBER_JWT_KEY}
		# Abonnés anonymes autorisés (nos topics de Turbo Streams sont publics)
		anonymous
		subscriptions
	}

	# Sert l'application Symfony (public/index.php)
	php_server
}
