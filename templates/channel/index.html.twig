{% extends 'layout/app.html.twig' %}

{% block title %}Canaux · OmniSync{% endblock %}
{% block page_title %}Canaux{% endblock %}

{% block app_content %}
    <p class="mb-6 text-sm text-gray-500">Canaux de synchronisation configurés. La connexion (URL, clé API) est définie par environnement.</p>

    <div class="overflow-hidden rounded-xl border border-gray-200 bg-white">
        <table class="w-full text-sm">
            <thead>
            <tr class="border-b border-gray-200 text-left text-xs font-medium uppercase tracking-wide text-gray-500">
                <th class="px-6 py-3">Canal</th>
                <th class="px-6 py-3">Code</th>
                <th class="px-6 py-3">Statut</th>
                <th class="px-6 py-3 text-right">Connexion</th>
            </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
            {% for channel in channels %}
                <tr data-controller="channel-test" data-channel-test-url-value="{{ path('app_channel_test', {id: channel.id}) }}">
                    <td class="px-6 py-4 font-medium text-gray-900">{{ channel.name }}</td>
                    <td class="px-6 py-4 font-mono text-xs text-gray-500">{{ channel.code }}</td>
                    <td class="px-6 py-4">
                        {% if channel.isActive %}
                            <span class="inline-flex rounded-full bg-emerald-50 px-2 py-0.5 text-xs font-medium text-emerald-700">Actif</span>
                        {% else %}
                            <span class="inline-flex rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-500">Inactif</span>
                        {% endif %}
                    </td>
                    <td class="px-6 py-4">
                        <div class="flex items-center justify-end gap-3">
                            <span data-channel-test-target="status" class="text-xs text-gray-400">Non testé</span>
                            <button type="button" data-action="channel-test#run" data-channel-test-target="button"
                                    class="cursor-pointer rounded-lg border border-gray-300 bg-white px-3 py-1.5 text-xs font-medium text-gray-700 transition hover:bg-gray-50 disabled:cursor-not-allowed disabled:opacity-50">
                                Tester
                            </button>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="px-6 py-12 text-center text-sm text-gray-500">Aucun canal configuré.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
