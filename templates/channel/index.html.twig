{% extends 'layout/app.html.twig' %}

{% block title %}Canaux · OmniSync{% endblock %}
{% block page_title %}Canaux{% endblock %}

{% block app_content %}
    <p class="mb-6 text-sm text-gray-500">{{ channels|length }} canal/canaux configuré(s)</p>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
        {% for channel in channels %}
            <div class="rounded-xl border border-gray-200 bg-white p-6">
                <div class="mb-4 flex items-start justify-between">
                    <div>
                        <h2 class="text-base font-semibold text-gray-900">{{ channel.name }}</h2>
                        <p class="font-mono text-xs text-gray-400">{{ channel.code }}</p>
                    </div>
                    {# Pastille de santé : vert si le canal répond, rouge sinon #}
                    {% if health[channel.id] %}
                        <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-medium text-emerald-700">
                            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
                            En ligne
                        </span>
                    {% else %}
                        <span class="inline-flex items-center gap-1.5 rounded-full bg-red-50 px-2.5 py-1 text-xs font-medium text-red-700">
                            <span class="h-1.5 w-1.5 rounded-full bg-red-500"></span>
                            Hors ligne
                        </span>
                    {% endif %}
                </div>

                <dl class="mb-5 space-y-1 text-xs text-gray-500">
                    <div class="flex justify-between">
                        <dt>Statut</dt>
                        <dd class="font-medium {{ channel.isActive ? 'text-gray-900' : 'text-gray-400' }}">
                            {{ channel.isActive ? 'Synchronisation active' : 'Synchronisation suspendue' }}
                        </dd>
                    </div>
                </dl>

                <form method="post" action="{{ path('app_channel_toggle', {id: channel.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('toggle_channel_' ~ channel.id) }}">
                    {% if channel.isActive %}
                        <button type="submit" class="w-full rounded-lg border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 transition hover:bg-gray-50 cursor-pointer">
                            Suspendre la synchronisation
                        </button>
                    {% else %}
                        <button type="submit" class="w-full rounded-lg bg-brand px-4 py-2 text-sm font-medium text-white transition hover:opacity-90 cursor-pointer">
                            Réactiver la synchronisation
                        </button>
                    {% endif %}
                </form>
            </div>
        {% endfor %}
    </div>
{% endblock %}
