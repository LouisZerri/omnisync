{% extends 'base.html.twig' %}

{% block title %}OmniSync — Synchronisation de catalogue multi-canal{% endblock %}

{% block body %}
<div class="overflow-x-hidden bg-white">
    {# ═══════════ HERO ═══════════ #}
    <section class="relative flex min-h-screen flex-col overflow-hidden bg-brand bg-cover bg-center"
             style="background-image: linear-gradient(to right, rgba(38,33,92,.95), rgba(38,33,92,.78)), url('/images/hero.jpg');">

        {# Barre de navigation transparente #}
        <header class="mx-auto flex w-full max-w-7xl items-center justify-between px-6 py-6 lg:px-8">
            <div class="flex items-center gap-2">
                <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-white/10 ring-1 ring-white/20">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
                </span>
                <span class="text-lg font-semibold text-white">OmniSync</span>
            </div>
            {% if app.user %}
                <a href="{{ path('app_home') }}" class="rounded-lg bg-white px-4 py-2 text-sm font-semibold text-brand transition hover:bg-white/90">Tableau de bord</a>
            {% else %}
                <a href="{{ path('app_login') }}" class="text-sm font-medium text-white/90 transition hover:text-white">Se connecter →</a>
            {% endif %}
        </header>

        <div class="mx-auto flex w-full max-w-7xl flex-1 items-center px-6 py-16 lg:px-8">
            <div class="max-w-2xl">
                <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1 text-xs font-medium text-white ring-1 ring-white/20">
                    <span class="h-1.5 w-1.5 rounded-full bg-brand-light"></span>SaaS de gestion de catalogue
                </span>
                <h1 class="mt-6 text-4xl font-bold tracking-tight text-white sm:text-5xl lg:text-6xl">
                    Pilotez votre catalogue multi-canal, en temps réel.
                </h1>
                <p class="mt-6 text-lg leading-8 text-white/80">
                    OmniSync synchronise vos produits, vos stocks et vos prix sur toutes vos marketplaces depuis une source unique de vérité — automatiquement, avec une architecture orientée messages fiable et un suivi en direct.
                </p>
                <div class="mt-10 flex flex-wrap items-center gap-4">
                    {% if app.user %}
                        <a href="{{ path('app_home') }}" class="rounded-lg bg-white px-6 py-3 text-base font-semibold text-brand shadow-sm transition hover:bg-white/90">Accéder au tableau de bord</a>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="rounded-lg bg-white px-6 py-3 text-base font-semibold text-brand shadow-sm transition hover:bg-white/90">Tester la démo</a>
                    {% endif %}
                    <a href="#fonctionnalites" class="rounded-lg px-6 py-3 text-base font-semibold text-white ring-1 ring-inset ring-white/30 transition hover:bg-white/10">Découvrir les fonctionnalités</a>
                </div>
                {% if not app.user %}
                    <p class="mt-6 text-sm text-white/60">Démo publique — comptes de test fournis sur la page de connexion.</p>
                {% endif %}
            </div>
        </div>
    </section>

    {# ═══════════ FONCTIONNALITÉS ═══════════ #}
    <section id="fonctionnalites" class="mx-auto max-w-7xl px-6 py-24 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
            <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Tout pour synchroniser sans friction</h2>
            <p class="mt-4 text-lg text-gray-600">Une plateforme pensée pour fiabiliser la diffusion de votre catalogue à grande échelle.</p>
        </div>

        <div class="mt-16 grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
            {% set features = [
                {'t': 'Synchronisation multi-canal', 'd': 'Diffusez fiches, prix et stocks sur toutes vos marketplaces depuis une source unique de vérité.', 'p': 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15'},
                {'t': 'Mises à jour en temps réel', 'd': 'Synchronisations et imports se mettent à jour en direct, sans recharger la page (Mercure + Turbo).', 'p': 'M13 10V3L4 14h7v7l9-11h-7z'},
                {'t': 'Architecture asynchrone', 'd': 'File de messages RabbitMQ : traitements en arrière-plan, retries automatiques, dead-letter, zéro perte.', 'p': 'M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4'},
                {'t': 'Import en masse', 'd': 'Importez votre catalogue par CSV, traité en tâche de fond avec un rapport détaillé des erreurs.', 'p': 'M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3'},
                {'t': 'Journal & supervision', 'd': 'Tracez chaque synchronisation, relancez les échecs en un clic, surveillez la santé des canaux.', 'p': 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z'},
                {'t': 'Rôles & permissions', 'd': 'Accès Administrateur / Gestionnaire pour cadrer précisément les permissions de chacun.', 'p': 'M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 008 11a4 4 0 118 0c0 1.017-.07 2.019-.203 3m-2.118 6.844A21.88 21.88 0 0015.171 17m3.839 1.132c.645-2.266.99-4.659.99-7.132A8 8 0 008 4.07M3 15.364c.64-1.319 1-2.8 1-4.364 0-1.457.39-2.823 1.07-4'},
            ] %}
            {% for f in features %}
                <div class="rounded-2xl border border-gray-200 bg-white p-6 transition hover:border-brand/30 hover:shadow-sm">
                    <span class="flex h-11 w-11 items-center justify-center rounded-xl bg-brand/10 text-brand">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="{{ f.p }}" /></svg>
                    </span>
                    <h3 class="mt-5 text-lg font-semibold text-gray-900">{{ f.t }}</h3>
                    <p class="mt-2 text-sm leading-6 text-gray-600">{{ f.d }}</p>
                </div>
            {% endfor %}
        </div>
    </section>

    {# ═══════════ STACK TECHNIQUE ═══════════ #}
    <section class="border-y border-gray-200 bg-gray-50">
        <div class="mx-auto max-w-7xl px-6 py-12 lg:px-8">
            <p class="text-center text-sm font-medium uppercase tracking-wide text-gray-500">Construit avec une stack moderne et éprouvée</p>
            <div class="mt-6 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm font-semibold text-gray-700">
                {% for tech in ['Symfony 7.4', 'PHP 8.4', 'RabbitMQ', 'Mercure', 'MySQL', 'Docker', 'FrankenPHP', 'Tailwind CSS'] %}
                    <span>{{ tech }}</span>
                {% endfor %}
            </div>
        </div>
    </section>

    {# ═══════════ CTA FINAL ═══════════ #}
    <section class="mx-auto max-w-7xl px-6 py-24 lg:px-8">
        <div class="rounded-3xl bg-brand px-8 py-16 text-center sm:px-16">
            <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">Envie de voir OmniSync en action ?</h2>
            <p class="mx-auto mt-4 max-w-xl text-lg text-white/80">Connectez-vous à la démo avec un compte de test et explorez la synchronisation multi-canal en temps réel.</p>
            <div class="mt-8 flex justify-center">
                {% if app.user %}
                    <a href="{{ path('app_home') }}" class="rounded-lg bg-white px-6 py-3 text-base font-semibold text-brand transition hover:bg-white/90">Accéder au tableau de bord</a>
                {% else %}
                    <a href="{{ path('app_login') }}" class="rounded-lg bg-white px-6 py-3 text-base font-semibold text-brand transition hover:bg-white/90">Tester la démo</a>
                {% endif %}
            </div>
        </div>
    </section>

    {# ═══════════ FOOTER ═══════════ #}
    <footer class="border-t border-gray-200">
        <div class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-4 px-6 py-8 text-sm text-gray-500 sm:flex-row lg:px-8">
            <div class="flex items-center gap-2">
                <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-brand">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
                </span>
                <span class="font-semibold text-gray-700">OmniSync</span>
            </div>
            <p>Projet réalisé pour un client · Démo publique. © 2026 Louis Zerri.</p>
        </div>
    </footer>
</div>
{% endblock %}
