{% extends 'base.html.twig' %}

{% block body %}
    <div class="flex min-h-screen bg-gray-50">
        {# Barre latérale de navigation #}
        <aside class="sticky top-0 flex h-screen w-60 flex-col self-start border-r border-gray-200 bg-white">
            <div class="flex h-16 items-center gap-2 border-b border-gray-200 px-6">
                <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-brand">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
                </span>
                <span class="text-lg font-semibold text-gray-900">OmniSync</span>
            </div>

            <nav class="flex-1 space-y-1 px-3 py-4">
                {{ _self.nav_item('app_home', 'Tableau de bord', app.request.attributes.get('_route') starts with 'app_home') }}
                {{ _self.nav_item('app_product_index', 'Produits', app.request.attributes.get('_route') starts with 'app_product') }}
                {{ _self.nav_item('app_import_index', 'Imports', app.request.attributes.get('_route') starts with 'app_import') }}
                {{ _self.nav_item('app_sync_index', 'Synchronisations', app.request.attributes.get('_route') starts with 'app_sync') }}
                {% if is_granted('ROLE_ADMIN') %}
                    {{ _self.nav_item('app_channel_index', 'Canaux', app.request.attributes.get('_route') starts with 'app_channel') }}
                {% endif %}
            </nav>
        </aside>

        {# Zone principale #}
        <div class="flex flex-1 flex-col">
            {# Barre du haut #}
            <header class="flex h-16 items-center justify-between border-b border-gray-200 bg-white px-8">
                <h1 class="text-lg font-medium text-gray-900">{% block page_title %}{% endblock %}</h1>
                <div class="flex items-center gap-4">
                    <span class="text-sm text-gray-600">{{ app.user.name }}</span>
                    <a href="{{ logout_path() }}" class="text-sm font-medium text-gray-500 transition hover:text-gray-900">Déconnexion</a>
                </div>
            </header>

            {# Contenu de la page #}
            <main class="flex-1 p-8">
                {% for message in app.flashes('success') %}
                    <div class="mb-6 flex items-center gap-2 rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                        {{ message }}
                    </div>
                {% endfor %}
                {% block app_content %}{% endblock %}
            </main>
        </div>
    </div>
{% endblock %}

{# Macro pour un lien de navigation, avec état actif #}
{% macro nav_item(route, label, active) %}
    <a href="{{ path(route) }}"
       class="block rounded-lg px-3 py-2 text-sm font-medium transition {{ active ? 'bg-brand text-white' : 'text-gray-700 hover:bg-gray-100' }}">
        {{ label }}
    </a>
{% endmacro %}
