{% extends 'layout/app.html.twig' %}

{% block title %}Importer un catalogue · OmniSync{% endblock %}
{% block page_title %}Importer un catalogue{% endblock %}

{% block app_content %}
    <div class="max-w-2xl rounded-xl border border-gray-200 bg-white p-8">
        <div class="mb-6 rounded-lg bg-gray-50 p-4 text-sm text-gray-600">
            <p class="mb-1 font-medium text-gray-900">Format attendu</p>
            <p>Un fichier CSV avec une ligne d'en-tête et les colonnes : <span class="font-mono text-xs">sku, name, description, price, stock</span>.</p>
            <p class="mt-1">Le prix est en euros (ex. <span class="font-mono text-xs">199.99</span>). Si une référence existe déjà, le produit est mis à jour.</p>
        </div>

        {{ form_start(form) }}
        <div data-controller="file-input">
            {{ form_label(form.file, null, {'label_attr': {'class': 'mb-1.5 block text-sm font-medium text-gray-700'}}) }}
            <label class="flex cursor-pointer flex-col items-center justify-center gap-2 rounded-lg border-2 border-dashed border-gray-300 bg-gray-50 px-6 py-8 text-center transition hover:border-brand hover:bg-brand/5">
                <svg class="h-8 w-8 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" /></svg>
                <span class="text-sm text-gray-600"><span class="font-semibold text-brand">Cliquez pour choisir</span> un fichier CSV</span>
                <span data-file-input-target="name" class="text-xs text-gray-400">Aucun fichier sélectionné</span>
                {{ form_widget(form.file, {'attr': {'class': 'sr-only', 'data-file-input-target': 'input', 'data-action': 'change->file-input#display'}}) }}
            </label>
            {{ form_errors(form.file) }}
        </div>
        <div class="mt-6 flex items-center gap-4">
            <button type="submit" class="cursor-pointer rounded-lg bg-brand px-4 py-2 text-sm font-medium text-white transition hover:opacity-90">
                Importer
            </button>
            <a href="{{ path('app_product_index') }}" class="text-sm font-medium text-gray-500 transition hover:text-gray-900">Annuler</a>
        </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
