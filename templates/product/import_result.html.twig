{% extends 'layout/app.html.twig' %}

{% block title %}Résultat de l'import · OmniSync{% endblock %}
{% block page_title %}Résultat de l'import{% endblock %}

{% block app_content %}
    <div class="max-w-2xl space-y-6">
        <div class="grid grid-cols-3 gap-4">
            <div class="rounded-xl border border-gray-200 bg-white p-5">
                <p class="text-sm text-gray-500">Créés</p>
                <p class="mt-1 text-2xl font-semibold text-gray-900">{{ result.created }}</p>
            </div>
            <div class="rounded-xl border border-gray-200 bg-white p-5">
                <p class="text-sm text-gray-500">Mis à jour</p>
                <p class="mt-1 text-2xl font-semibold text-gray-900">{{ result.updated }}</p>
            </div>
            <div class="rounded-xl border border-gray-200 bg-white p-5">
                <p class="text-sm text-gray-500">Erreurs</p>
                <p class="mt-1 text-2xl font-semibold {{ result.hasErrors ? 'text-red-600' : 'text-gray-900' }}">{{ result.errors|length }}</p>
            </div>
        </div>

        {% if result.hasErrors %}
            <div class="overflow-hidden rounded-xl border border-gray-200 bg-white">
                <div class="flex items-center justify-between border-b border-gray-200 px-6 py-3">
                    <span class="text-sm font-medium text-gray-900">Lignes en erreur</span>
                    <span class="rounded-full bg-red-50 px-2 py-0.5 text-xs font-medium text-red-700">{{ result.errors|length }}</span>
                </div>
                <div class="max-h-96 overflow-y-auto">
                    <table class="w-full text-sm">
                        <tbody class="divide-y divide-gray-100">
                        {% for line, message in result.errors %}
                            <tr>
                                <td class="whitespace-nowrap px-6 py-3 font-mono text-xs text-gray-500">{% if line == 0 %}Fichier{% else %}Ligne {{ line }}{% endif %}</td>
                                <td class="px-6 py-3 text-red-700">{{ message }}</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        {% endif %}

        <div>
            <a href="{{ path('app_product_index') }}" class="text-sm font-medium text-brand transition hover:underline">← Retour au catalogue</a>
        </div>
    </div>
{% endblock %}
