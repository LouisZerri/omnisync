{% extends 'layout/app.html.twig' %}

{% block title %}Produits · OmniSync{% endblock %}
{% block page_title %}Produits{% endblock %}

{% block app_content %}
    <div class="mb-6 flex items-center justify-between">
        <p class="text-sm text-gray-500">{{ pagination.getTotalItemCount }} produit(s) au catalogue</p>
        <div class="flex items-center gap-3">
            <a href="{{ path('app_product_import') }}" class="rounded-lg border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 transition hover:bg-gray-50">
                Importer un CSV
            </a>
            <a href="{{ path('app_product_new') }}" class="rounded-lg bg-brand px-4 py-2 text-sm font-medium text-white transition hover:opacity-90">
                Nouveau produit
            </a>
        </div>
    </div>

    <div class="overflow-hidden rounded-xl border border-gray-200 bg-white" data-controller="lightbox">
        <table class="w-full text-sm">
            <thead>
            <tr class="border-b border-gray-200 text-left text-xs font-medium uppercase tracking-wide text-gray-500">
                <th class="px-6 py-3">Produit</th>
                <th class="px-6 py-3">Référence</th>
                <th class="px-6 py-3 text-right">Prix</th>
                <th class="px-6 py-3 text-right">Stock</th>
                <th class="px-6 py-3 text-right">Actions</th>
            </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
            {% for product in pagination %}
                <tr class="transition hover:bg-gray-50">
                    <td class="px-6 py-4">
                        <div class="flex items-center gap-3">
                            <div class="flex h-10 w-10 shrink-0 items-center justify-center overflow-hidden rounded-lg border border-gray-200 bg-gray-50">
                                {% if product.imageName %}
                                    <img src="{{ vich_uploader_asset(product, 'imageFile') }}" alt="{{ product.name }}" class="h-full w-full cursor-zoom-in object-cover" data-action="click->lightbox#open">
                                {% else %}
                                    <svg class="h-5 w-5 text-gray-300" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" /></svg>
                                {% endif %}
                            </div>
                            <span class="font-medium text-gray-900">{{ product.name }}</span>
                        </div>
                    </td>
                    <td class="px-6 py-4 font-mono text-xs text-gray-500">{{ product.sku }}</td>
                    <td class="px-6 py-4 text-right text-gray-900">{{ (product.priceCents / 100)|number_format(2, ',', ' ') }} €</td>
                    <td class="px-6 py-4 text-right">
                        {% if product.stock == 0 %}
                            <span class="inline-flex rounded-full bg-red-50 px-2 py-0.5 text-xs font-medium text-red-700">Rupture</span>
                        {% else %}
                            <span class="text-gray-900">{{ product.stock }}</span>
                        {% endif %}
                    </td>
                    <td class="px-6 py-4">
                        <div class="flex items-center justify-end gap-3">
                            <form method="post" action="{{ path('app_product_sync', {id: product.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('sync_product_' ~ product.id) }}">
                                <button type="submit" class="cursor-pointer text-sm font-medium text-brand transition hover:underline">Synchroniser</button>
                            </form>
                            <a href="{{ path('app_product_edit', {id: product.id}) }}" class="text-sm font-medium text-gray-600 transition hover:underline">Modifier</a>
                            <form method="post" action="{{ path('app_product_delete', {id: product.id}) }}" data-controller="confirm" data-confirm-message-value="Supprimer le produit « {{ product.name }} » ?">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_product_' ~ product.id) }}">
                                <button type="submit" class="cursor-pointer text-sm font-medium text-gray-400 transition hover:text-red-600">Supprimer</button>
                            </form>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="px-6 py-12 text-center text-sm text-gray-500">Aucun produit au catalogue.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    {% if pagination.getPageCount > 1 %}
        <div class="mt-6 flex justify-center">
            {{ knp_pagination_render(pagination) }}
        </div>
    {% endif %}
{% endblock %}
