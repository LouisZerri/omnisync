{% extends 'layout/auth.html.twig' %}

{% block title %}E-mail envoyé · OmniSync{% endblock %}

{% block auth_content %}
    <div class="flex min-h-screen">
        {% include 'layout/_brand_panel.html.twig' %}

        <div class="flex w-full flex-col justify-center px-6 py-12 lg:w-3/5 lg:px-16">
            <div class="mx-auto w-full max-w-xl">
                {% include 'layout/_brand_logo_mobile.html.twig' %}

                <span class="mb-6 flex h-12 w-12 items-center justify-center rounded-full bg-emerald-50">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                </span>

                <h1 class="text-3xl font-bold text-gray-900">Vérifiez votre boîte mail</h1>
                <p class="mt-2 text-base text-gray-500">
                    Si un compte correspond à cette adresse, un e-mail contenant un lien de réinitialisation vient d'être envoyé.
                    Ce lien expirera dans {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}.
                </p>
                <p class="mt-4 text-sm text-gray-500">
                    Vous ne recevez rien ? Vérifiez vos spams ou
                    <a href="{{ path('app_forgot_password_request') }}" class="font-medium text-brand hover:underline">réessayez</a>.
                </p>

                <p class="mt-6 text-sm text-gray-500">
                    <a href="{{ path('app_login') }}" class="font-medium text-brand hover:underline">← Retour à la connexion</a>
                </p>
            </div>
        </div>
    </div>
{% endblock %}
