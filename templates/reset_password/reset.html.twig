{% extends 'layout/auth.html.twig' %}

{% block title %}Nouveau mot de passe · OmniSync{% endblock %}

{% block auth_content %}
    <div class="flex min-h-screen">
        {% include 'layout/_brand_panel.html.twig' %}

        <div class="flex w-full flex-col justify-center px-6 py-12 lg:w-3/5 lg:px-16">
            <div class="mx-auto w-full max-w-xl">
                {% include 'layout/_brand_logo_mobile.html.twig' %}

                <h1 class="text-3xl font-bold text-gray-900">Nouveau mot de passe</h1>
                <p class="mt-2 text-base text-gray-500">Choisissez un nouveau mot de passe pour votre compte.</p>

                {{ form_start(resetForm, {attr: {class: 'mt-8 space-y-5'}}) }}
                    {# Nouveau mot de passe : œil + indicateur de force #}
                    <div data-controller="password-strength">
                        <label for="{{ resetForm.plainPassword.first.vars.id }}" class="mb-1.5 block text-sm font-medium text-gray-700">Nouveau mot de passe</label>
                        <div class="relative" data-controller="password-toggle">
                            {{ form_widget(resetForm.plainPassword.first, {attr: {
                                class: 'block w-full rounded-lg border border-gray-300 px-4 py-3 pr-11 text-base text-gray-900 focus:border-brand focus:outline-none focus:ring-1 focus:ring-brand',
                                'data-password-toggle-target': 'input',
                                'data-password-strength-target': 'password',
                                'data-action': 'input->password-strength#check',
                            }}) }}
                            <button type="button" data-action="password-toggle#toggle" tabindex="-1"
                                    class="absolute inset-y-0 right-0 flex items-center pr-3 text-gray-400 hover:text-gray-600"
                                    aria-label="Afficher ou masquer le mot de passe">
                                <svg data-password-toggle-target="iconShow" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                                <svg data-password-toggle-target="iconHide" xmlns="http://www.w3.org/2000/svg" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" /></svg>
                            </button>
                        </div>
                        <div class="mt-1 text-sm text-red-600">{{ form_errors(resetForm.plainPassword.first) }}</div>

                        <ul class="mt-3 grid grid-cols-1 gap-1.5 text-sm sm:grid-cols-2">
                            <li data-password-strength-target="length" class="flex items-center gap-2 text-gray-400">
                                <span data-dot class="h-1.5 w-1.5 rounded-full bg-gray-300"></span>Au moins 8 caractères
                            </li>
                            <li data-password-strength-target="upper" class="flex items-center gap-2 text-gray-400">
                                <span data-dot class="h-1.5 w-1.5 rounded-full bg-gray-300"></span>Une lettre majuscule
                            </li>
                            <li data-password-strength-target="lower" class="flex items-center gap-2 text-gray-400">
                                <span data-dot class="h-1.5 w-1.5 rounded-full bg-gray-300"></span>Une lettre minuscule
                            </li>
                            <li data-password-strength-target="special" class="flex items-center gap-2 text-gray-400">
                                <span data-dot class="h-1.5 w-1.5 rounded-full bg-gray-300"></span>Un caractère spécial
                            </li>
                        </ul>
                    </div>

                    {# Confirmation : œil #}
                    <div>
                        <label for="{{ resetForm.plainPassword.second.vars.id }}" class="mb-1.5 block text-sm font-medium text-gray-700">Confirmer le mot de passe</label>
                        <div class="relative" data-controller="password-toggle">
                            {{ form_widget(resetForm.plainPassword.second, {attr: {
                                class: 'block w-full rounded-lg border border-gray-300 px-4 py-3 pr-11 text-base text-gray-900 focus:border-brand focus:outline-none focus:ring-1 focus:ring-brand',
                                'data-password-toggle-target': 'input',
                            }}) }}
                            <button type="button" data-action="password-toggle#toggle" tabindex="-1"
                                    class="absolute inset-y-0 right-0 flex items-center pr-3 text-gray-400 hover:text-gray-600"
                                    aria-label="Afficher ou masquer le mot de passe">
                                <svg data-password-toggle-target="iconShow" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                                <svg data-password-toggle-target="iconHide" xmlns="http://www.w3.org/2000/svg" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" /></svg>
                            </button>
                        </div>
                        <div class="mt-1 text-sm text-red-600">{{ form_errors(resetForm.plainPassword.second) }}</div>
                    </div>

                    <button type="submit"
                            class="mt-2 w-full cursor-pointer rounded-lg bg-brand px-4 py-3 text-base font-semibold text-white transition hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-brand focus:ring-offset-2">
                        Réinitialiser le mot de passe
                    </button>
                {{ form_end(resetForm) }}
            </div>
        </div>
    </div>
{% endblock %}
