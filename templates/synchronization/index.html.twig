{% extends 'layout/app.html.twig' %}

{% block title %}Synchronisations · OmniSync{% endblock %}
{% block page_title %}Synchronisations{% endblock %}

{% block app_content %}
    <p class="mb-6 text-sm text-gray-500">{{ pagination.getTotalItemCount }} synchronisation(s) au journal</p>

    <div class="overflow-hidden rounded-xl border border-gray-200 bg-white">
        <table class="w-full text-sm">
            <thead>
            <tr class="border-b border-gray-200 text-left text-xs font-medium uppercase tracking-wide text-gray-500">
                <th class="px-6 py-3">Produit</th>
                <th class="px-6 py-3">Canal</th>
                <th class="px-6 py-3">Statut</th>
                <th class="px-6 py-3">Mise à jour</th>
                <th class="px-6 py-3">Détail</th>
            </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
            {% for sync in pagination %}
                {% set badge = {
                    'pending': 'bg-gray-100 text-gray-600',
                    'running': 'bg-amber-50 text-amber-700',
                    'done': 'bg-emerald-50 text-emerald-700',
                    'failed': 'bg-red-50 text-red-700',
                }[sync.status.value] %}
                <tr class="transition hover:bg-gray-50">
                    <td class="px-6 py-4 font-medium text-gray-900">{{ sync.product.name }}</td>
                    <td class="px-6 py-4 text-gray-600">{{ sync.channel.name }}</td>
                    <td class="px-6 py-4">
                        <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium {{ badge }}">{{ sync.status.label }}</span>
                    </td>
                    <td class="px-6 py-4 font-mono text-xs text-gray-500">{{ sync.updatedAt|date('d/m/Y H:i:s') }}</td>
                    <td class="px-6 py-4 text-xs text-red-600">{{ sync.error }}</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="px-6 py-12 text-center text-sm text-gray-500">Aucune synchronisation pour le moment.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    {% if pagination.getPageCount > 1 %}
        <div class="mt-6 flex justify-center">
            {{ knp_pagination_render(pagination) }}
        </div>
    {% endif %}
{% endblock %}
